<h1 class="text-2xl font-bold text-gray-900 mb-2">Edit Profile</h1>
<p class="text-sm text-gray-500 mb-6">This is your master professional profile. Be as detailed as possible — the AI uses this to score job offers and generate all documents.</p>

<div class="bg-white shadow rounded-lg p-6">
  <%= form_with model: @profile, url: profile_path, class: "space-y-6" do |f| %>
    <% if @profile.errors.any? %>
      <div class="rounded-md bg-red-50 border border-red-200 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
            <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
              <% @profile.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="space-y-2">
      <%= f.label :name, "Name", class: "block text-sm font-semibold text-gray-700" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <%= f.text_field :name, 
            class: "block w-full pl-10 pr-4 py-3 border-2 border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition-all duration-150 ease-in-out sm:text-sm",
            placeholder: "Your full name" %>
      </div>
    </div>

    <div class="space-y-2">
      <%= f.label :content, "Profile Content", class: "block text-sm font-semibold text-gray-700" %>
      <div class="relative">
        <%= f.text_area :content, 
            rows: 25, 
            class: "block w-full p-4 border-2 border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition-all duration-150 ease-in-out font-mono text-sm resize-y min-h-[400px] scrollbar-thin scrollbar-thumb-gray-400 scrollbar-track-gray-100",
            placeholder: "# Your Name

## Professional Summary
Write a compelling 3-4 sentence summary of your experience and expertise.

## Technical Skills
- Languages: Ruby, Python, JavaScript
- Frameworks: Rails, Django, React
- Databases: PostgreSQL, Redis
- Cloud: AWS, Docker, Kubernetes

## Professional Experience

### Senior Developer | Company Name | 2020 - Present
- Built scalable API serving 1M+ requests/day
- Reduced database queries by 60% through optimization
- Led team of 5 developers

## Education
B.S. Computer Science - University Name (2015)

## Work Style
Remote experience, async communication, collaborative

## Languages
English (Native), Spanish (Conversational)" %>
      </div>
      <div class="flex items-center justify-between">
        <p class="text-sm text-gray-500">
          Use Markdown formatting. Include your full professional background.
        </p>
        <span class="text-xs text-gray-400" id="char-count"></span>
      </div>
    </div>

    <%# AI Provider Configuration Section %>
    <div class="pt-6 border-t border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">AI Provider Configuration</h2>
      
      <div class="space-y-2 mb-6">
        <%= f.label :ai_provider, "Active Provider", class: "block text-sm font-semibold text-gray-700" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.select :ai_provider, 
              [['Anthropic', 'anthropic'], ['Mistral', 'mistral'], ['OpenAI', 'openai'], ['Kimi', 'kimi'], ['GLM', 'glm']],
              {},
              class: "block w-full pl-10 pr-10 py-3 border-2 border-gray-300 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition-all duration-150 ease-in-out appearance-none bg-white sm:text-sm cursor-pointer" %>
          <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none">
            <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
        <p class="text-sm text-gray-500">Select which AI provider to use for job analysis and document generation.</p>
      </div>

      <%# API Keys for all providers %>
      <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">API Keys</h3>
        <p class="text-xs text-gray-500 mb-4">API keys are encrypted at rest and never logged. You only need to fill in the key for your active provider.</p>

        <%= f.fields_for :ai_credentials do |cred| %>
          <% provider = cred.object.provider %>
          <div class="mb-4 last:mb-0" data-provider="<%= provider %>">
            <%= cred.hidden_field :provider %>
            <%= cred.hidden_field :id %>
            
            <div class="flex items-center justify-between mb-2">
              <%= cred.label :api_key, provider.camelcase, class: "block text-sm font-medium text-gray-700" %>
              <% if @profile.has_credential_for?(provider) %>
                <span class="text-xs text-green-600 font-medium">
                  <svg class="inline h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Key saved
                </span>
              <% end %>
            </div>
            
            <div class="relative">
              <% if @profile.api_key_for(provider).present? %>
                <%# Key exists - show empty field with note that key is saved %>
                <%= cred.password_field :api_key, 
                    class: "block w-full pr-12 py-3 border-2 border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition-all duration-150 ease-in-out sm:text-sm font-mono",
                    placeholder: "Key saved - enter new value to change" %>
              <% else %>
                <%# No key - show empty field %>
                <%= cred.password_field :api_key, 
                    class: "block w-full pr-12 py-3 border-2 border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white transition-all duration-150 ease-in-out sm:text-sm font-mono",
                    placeholder: "Enter #{provider.camelcase} API key" %>
              <% end %>
              <button type="button" 
                      class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-400 hover:text-gray-600 focus:outline-none"
                      onclick="togglePasswordVisibility(this)">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
            </div>
            
            <script>
              function togglePasswordVisibility(button) {
                const input = button.previousElementSibling;
                if (input.type === 'password') {
                  input.type = 'text';
                  button.innerHTML = '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>';
                } else {
                  input.type = 'password';
                  button.innerHTML = '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>';
                }
              }
            </script>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-between pt-6 border-t border-gray-200">
      <%= link_to "Cancel", profile_path, class: "inline-flex justify-center py-2.5 px-5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-150" %>
      <%= f.submit "Save Profile", 
          class: "inline-flex justify-center items-center py-2.5 px-6 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-150 ease-in-out",
          data: { disable_with: "Saving..." } %>
    </div>
  <% end %>
</div>
